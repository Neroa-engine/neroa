{
  "manifest_version": 3,
  "name": "Neroa Live View",
  "version": "0.1.0",
  "description": "Inspect local, preview, and production runtime targets in real time and send Live View signals back to Neroa.",
  "permissions": ["activeTab", "storage", "tabs", "scripting", "sidePanel"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Open Neroa Live View"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js", "assets/neroa-mark.svg"],
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*/*"
      ]
    }
  ]
}
