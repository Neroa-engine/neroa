{
  "manifest_version": 3,
  "name": "Neroa Live View",
  "version": "0.1.0",
  "description": "Inspect localhost apps in real time and send Live View QA signals back to Neroa.",
  "permissions": ["activeTab", "storage", "tabs", "scripting", "sidePanel"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://localhost:3002/*",
    "http://127.0.0.1:3000/*",
    "http://127.0.0.1:3001/*",
    "http://127.0.0.1:3002/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Open Neroa Live View"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://localhost:3002/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:3001/*",
        "http://127.0.0.1:3002/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js", "assets/neroa-mark.svg"],
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://localhost:3002/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:3001/*",
        "http://127.0.0.1:3002/*"
      ]
    }
  ]
}
