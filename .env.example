NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_RUNTIME_PRODUCTION_ORIGINS=https://your-domain.com
NEXT_PUBLIC_RUNTIME_PREVIEW_ORIGINS=https://deploy-preview-123--your-site.netlify.app
NEXT_PUBLIC_RUNTIME_STAGING_ORIGINS=https://staging.your-domain.com
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_CODEX_MODEL=gpt-5.4-mini
GITHUB_TOKEN=your-github-token
RESEND_API_KEY=your-resend-api-key
CONTACT_FROM_EMAIL="Neroa <onboarding@resend.dev>"

# Build Room v1
# Optional: force the relay mode. Leave unset to use the real Codex relay when OPENAI_API_KEY is present.
# BUILD_ROOM_CODEX_MODE=real
# Optional: override the default Build Room model.
# BUILD_ROOM_CODEX_MODEL=gpt-5-codex-mini

# First live rollout should stay in governed dry-run mode unless you explicitly promote the worker.
BUILD_ROOM_WORKER_MODE=mock
# BUILD_ROOM_WORKER_ENDPOINT=https://your-worker-endpoint.example.com
# BUILD_ROOM_WORKER_SHARED_SECRET=your-worker-shared-secret
# BUILD_ROOM_WORKER_CALLBACK_SECRET=your-worker-callback-secret
# BUILD_ROOM_WORKER_CALLBACK_BASE_URL=https://your-neroa-site.example.com
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
